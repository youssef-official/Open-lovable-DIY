# Open Lovable DIY - Environment Variables
# Copy this file to .env.local and fill in your API keys

# REQUIRED - Code execution sandboxes
# Get your API key from: https://e2b.dev
E2B_API_KEY=your_e2b_api_key_here

# REQUIRED - AI inference
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OPTIONAL - Additional AI providers
# Get your API key from: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# OPTIONAL - Google OAuth Authentication
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# REQUIRED - NextAuth.js configuration
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# REQUIRED - Neon Database
DATABASE_URL=your_database_url_here

# OPTIONAL - Application configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# REQUIRED - Netlify Deployment Integration
# Get your OAuth app credentials from: https://app.netlify.com/user/applications
# Instructions:
# 1. Go to https://app.netlify.com/user/applications
# 2. Click "New OAuth application"
# 3. Name it whatever you like (e.g., "Youssef AI")
# 4. For Redirect URI, use: YOUR_APP_URL/api/netlify/callback
#    - Local dev: http://localhost:3000/api/netlify/callback
#    - Production: https://your-domain.com/api/netlify/callback
# 5. Copy the Client ID and Client Secret below
NETLIFY_CLIENT_ID=your_netlify_client_id_here
NETLIFY_CLIENT_SECRET=your_netlify_client_secret_here
# Set this to match your redirect URI above
NETLIFY_REDIRECT_URI=http://localhost:3000/api/netlify/callback
